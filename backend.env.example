# Copy this file to backend/.env and fill in real values. Never commit the real .env.

APP_ENV=development
HTTP_PORT=8080

# Database
DATABASE_URL=postgres://user:password@localhost:5432/meryata_souq?sslmode=disable

# Redis (config cache, OTP store, WS presence, rate limiting)
REDIS_URL=redis://localhost:6379/0

# Auth
# Access tokens stay short-lived (memory-only on mobile, silently rotated via
# /auth/refresh). The refresh token is what keeps a user logged in — it lives
# in the OS keychain and is only invalidated by an explicit logout, so it is
# deliberately long (1 year).
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=8760h

# OTP
OTP_TTL_SECONDS=300
OTP_LENGTH=6

# OTP providers (both wired behind an interface; active one chosen at runtime via app_configs.otp_provider)
# SMS provider: Upsilon (smsapi.upsilonlb.com)
SMS_USERNAME=
SMS_PASSWORD=
SMS_SENDER_ID=
WHATSAPP_API_KEY=

# Push notifications
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

# Routing engine for driver route geometry + ETA (self-hosted OSRM — see
# docker-compose.yml and docs/OSRM.md). The public demo server forbids
# commercial use, so never point this at router.project-osrm.org.
OSRM_URL=http://localhost:5000

# Storage (local | s3 — switchable at runtime via app_configs.storage_driver)
STORAGE_DRIVER=local
MEDIA_LOCAL_DIR=./media

AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Localization & currency defaults (seeded into app_configs on first boot)
BASE_CURRENCY=USD
DEFAULT_LOCALE=en

# CORS — comma-separated allowlist, no wildcard with credentials
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
