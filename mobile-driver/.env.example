# API base URL for the Expo mobile client
# - For iOS Simulator / Web: use http://localhost:8080/api/v1
# - For Android Emulator: use http://10.0.2.2:8080/api/v1
# - For Physical Devices: use your computer's local network IP (e.g., http://192.168.1.100:8080/api/v1)
EXPO_PUBLIC_API_URL=http://localhost:8080/api/v1
