VITE_API_BASE_URL=http://localhost:8080/api/v1
# Media origin, used when the backend returns a RELATIVE image path
# (e.g. "/media/products/x.png"). Set the ORIGIN — a trailing "/media" is
# stripped automatically. Leave empty when the backend returns absolute URLs.
VITE_MEDIA_BASE_URL=https://souq-api.linksbridge.top
